{
  "name": "draftbridge",
  "private": true,
  "scripts": {
    "build": "react-router build",
    "dev": "npx @shopify/cli@latest app dev",
    "docker-start": "npm run render:start",
    "config:link": "npx @shopify/cli@latest app config link",
    "generate": "npx @shopify/cli@latest app generate",
    "deploy": "npx @shopify/cli@latest app deploy",
    "config:use": "npx @shopify/cli@latest app config use",
    "env": "npx @shopify/cli@latest app env",
    "start": "react-router-serve ./build/server/index.js",
    "setup": "npm run db:generate && npm run db:deploy",
    "lint": "eslint --ignore-path .eslintignore --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "npx @shopify/cli@latest",
    "prisma": "prisma",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:deploy": "prisma migrate deploy",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "data:prune": "tsx scripts/prune-uninstalled-shops.ts",
    "render:build": "npm run db:generate && npm run build && node scripts/patch-prisma-server-build.mjs",
    "render:start": "npm run start",
    "test": "vitest run",
    "test:watch": "vitest",
    "vite": "vite",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "type": "module",
  "engines": {
    "node": ">=20.19 <22 || >=22.12"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.883.0",
    "@prisma/client": "^6.16.3",
    "@react-router/dev": "^7.12.0",
    "@react-router/fs-routes": "^7.12.0",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@shopify/app-bridge-react": "^4.2.4",
    "@shopify/shopify-app-react-router": "^1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "^8.0.0",
    "isbot": "^5.1.31",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "prisma": "^6.16.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.12.0",
    "vite-tsconfig-paths": "^5.1.4",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@shopify/polaris-types": "^1.0.1",
    "@types/eslint": "^9.6.1",
    "@types/node": "^22.18.8",
    "@types/react": "^18.3.25",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.1",
    "eslint-import-resolver-typescript": "^3.10.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "tsx": "^4.20.5",
    "vite": "^6.3.6",
    "vitest": "^3.2.4"
  },
  "workspaces": {
    "packages": [
      "extensions/*"
    ]
  },
  "trustedDependencies": [
    "@shopify/plugin-cloudflare"
  ],
  "overrides": {
    "p-map": "^4.0.0"
  }
}
